# ══════════════════════════════════════════════════════════════
# SENTINEL Environment Variables
# All OSINT sources work with REAL APIs — no mock data
# ══════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev

# ── Memgraph (Graph Database) ──────────────────────────────
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USER=sentinel
MEMGRAPH_PASSWORD=sentinel_dev

# ── Redis (PubSub + Cache) ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sentinel_dev

# ── Y-Sweet (CRDT Collaboration) ──────────────────────────
Y_SWEET_URL=http://localhost:8080

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=sentinel-dev-secret-change-in-production
JWT_EXPIRES_IN=24h

# ── AWS (for Amazon Nova AI models) ────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ══════════════════════════════════════════════════════════════
# OSINT DATA SOURCES — Real-time public APIs
# Sources marked [NO AUTH] work immediately without any key
# ══════════════════════════════════════════════════════════════

# ── Aviation [NO AUTH for primary] ─────────────────────────
# Primary: Airplanes.live (no key needed, 1 req/sec)
# Failover: adsb.lol (no key needed, same v2 format)
# Enrichment: OpenSky Network (optional, +4000 credits/day)
OPENSKY_USERNAME=                  # Optional: register at opensky-network.org
OPENSKY_PASSWORD=

# ── Maritime [FREE API KEY] ────────────────────────────────
# Primary: AISStream.io WebSocket (real-time global AIS)
AISSTREAM_API_KEY=                 # Register free: aisstream.io (GitHub login)
# Analytics: Global Fishing Watch (vessel identity + ownership)
GFW_TOKEN=                         # Register free: globalfishingwatch.org/our-apis/tokens

# ── Conflict & Events [NO AUTH for GDELT] ──────────────────
# Primary: GDELT 2.0 (no key needed, 15-min refresh)
# Supplemental: ACLED (structured conflict events)
ACLED_API_KEY=                     # Register free: developer.acleddata.com
ACLED_EMAIL=

# ── Natural Disasters [NO AUTH] ────────────────────────────
# USGS Earthquakes: No key needed (real-time GeoJSON feeds)
# NOAA Weather Alerts: No key needed (User-Agent header used)

# ── Internet Outages [NO AUTH] ─────────────────────────────
# IODA (Georgia Tech): No key needed (5-min resolution)

# ── Satellites [FREE REGISTRATION] ─────────────────────────
# Primary: Space-Track.org (strict rate limits: 30 req/min)
SPACETRACK_USERNAME=               # Register free: space-track.org
SPACETRACK_PASSWORD=
# Fallback: CelesTrak (no key needed)

# ── NOTAMs [FREE REGISTRATION] ─────────────────────────────
FAA_CLIENT_ID=                     # Register free: api.faa.gov
FAA_CLIENT_SECRET=

# ── Fire Detection [FREE REGISTRATION] ─────────────────────
FIRMS_MAP_KEY=                     # Register free: firms.modaps.eosdis.nasa.gov/api

# ── Sanctions [FREE FOR NON-COMMERCIAL] ────────────────────
OPENSANCTIONS_API_KEY=             # Register free: opensanctions.org

# ── Entity Enrichment ──────────────────────────────────────
# Wikidata: No key needed
# CIA World Factbook: No key needed (static JSON)
OPENCORPORATES_TOKEN=              # Free tier: 200 req/month, register: opencorporates.com

# ══════════════════════════════════════════════════════════════
# AMAZON NOVA AI MODELS (via AWS Bedrock)
# Uses AWS credentials above — no separate keys needed
# ══════════════════════════════════════════════════════════════
# Models used by SENTINEL:
#   us.amazon.nova-2-lite-v1:0          Entity extraction from OSINT text
#   amazon.nova-2-sonic-v1:0            Voice intelligence assistant
#   us.amazon.nova-pro-v1:0             Multimodal anomaly analysis
#   us.amazon.nova-premier-v1:0         Deep reasoning + briefing generation
#   amazon.nova-canvas-v1:0             Satellite imagery annotation
#   amazon.nova-reel-v1:1               Scenario visualization (async)
#   amazon.nova-2-multimodal-embeddings-v1:0  Semantic search embeddings

# ── Nova Act (separate Python SDK) ─────────────────────────
NOVA_ACT_API_KEY=
