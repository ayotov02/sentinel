{
  "name": "@sentinel/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "db:migrate": "node -e \"const {readFileSync}=require('fs');const {Client}=require('pg');const c=new Client({host:process.env.POSTGRES_HOST||'localhost',port:5432,database:process.env.POSTGRES_DB||'sentinel',user:process.env.POSTGRES_USER||'sentinel',password:process.env.POSTGRES_PASSWORD||'sentinel_dev'});c.connect().then(()=>c.query(readFileSync('./src/modules/database/migrations/001-initial.sql','utf8'))).then(()=>c.query(readFileSync('./src/modules/database/migrations/002-extensions.sql','utf8'))).then(()=>{console.log('Migrations complete');c.end()}).catch(e=>{console.error(e);c.end();process.exit(1)})\"",
    "db:seed": "ts-node ../scripts/seed-data.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/websockets": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/config": "^3.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@smithy/node-http-handler": "^3.3.0",
    "@y-sweet/sdk": "^0.6.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "neo4j-driver": "^5.27.0",
    "ioredis": "^5.4.0",
    "bcryptjs": "^2.4.3",
    "uuid": "^11.0.0",
    "rxjs": "^7.8.0",
    "reflect-metadata": "^0.2.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "@sentinel/shared": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0"
  }
}
